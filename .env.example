# OpenClaw Foundry Environment Variables
# Copy this file to .env and fill in your values

# ── Frontend (web/) ──────────────────────────────
# API URL for the Workers backend (default: local dev)
OCF_API_URL=http://localhost:8787

# ── Cloudflare (worker/) ─────────────────────────
# These are configured in wrangler.toml, not env vars.
# See worker/wrangler.toml.example for D1/R2/KV bindings.

# ── GitHub Actions CI/CD ─────────────────────────
# Add these as GitHub repository secrets:
# CLOUDFLARE_API_TOKEN  — Create at https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_ACCOUNT_ID — Found in your Cloudflare dashboard URL
