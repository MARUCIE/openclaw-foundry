{
  "name": "openclaw-foundry-api",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create openclaw-foundry",
    "db:migrate": "wrangler d1 execute openclaw-foundry --file=src/schema.sql",
    "db:seed": "wrangler d1 execute openclaw-foundry --file=src/seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
