#:schema node_modules/wrangler/config-schema.json
name = "openclaw-foundry-api"
main = "src/index.ts"
compatibility_date = "2025-06-01"
compatibility_flags = ["nodejs_compat"]

# D1 SQL Database
[[d1_databases]]
binding = "DB"
database_name = "openclaw-foundry"
database_id = "YOUR_D1_DATABASE_ID"

# R2 Object Storage
[[r2_buckets]]
binding = "STORAGE"
bucket_name = "openclaw-foundry-files"

# KV Cache
[[kv_namespaces]]
binding = "CACHE"
id = "YOUR_KV_NAMESPACE_ID"

# Cron triggers
[triggers]
crons = ["0 6 * * *"]

[vars]
ENVIRONMENT = "production"
