{
  "version": "1.0",
  "meta": {
    "name": "Compliance Specialist",
    "os": "darwin",
    "created": "2026-03-10",
    "profile": "compliance",
    "description": "Compliance setup with audit, policy drafting, NDA, and regulatory tracking tools"
  },
  "openclaw": { "version": "latest", "installMethod": "npm" },
  "identity": {
    "role": "Compliance / Legal Specialist",
    "soulTemplate": "compliance"
  },
  "skills": {
    "fromAifleet": [
      "compliance-docs", "privacy-policy", "draft-nda",
      "create-prd", "test-scenarios", "grammar-check",
      "search-first", "deep-research", "sentiment-analysis"
    ],
    "fromClawhub": ["summarize-pro"],
    "custom": []
  },
  "agents": [
    { "name": "main", "role": "Compliance and policy assistant", "jobs": ["policy-drafting", "audit-prep", "regulation-tracking"] },
    { "name": "researcher", "role": "Regulatory research specialist", "jobs": ["regulation-monitoring", "case-analysis"] }
  ],
  "config": {
    "autonomy": "L1-guided",
    "modelRouting": "premium",
    "memoryChunks": 72
  },
  "cron": [
    { "schedule": "0 8 * * 1-5", "job": "regulation-digest", "description": "Daily regulatory news digest on weekdays" }
  ],
  "mcpServers": ["github"],
  "extensions": []
}
