{
  "version": "1.0",
  "meta": {
    "name": "DevOps / SRE",
    "os": "linux",
    "created": "2026-03-10",
    "profile": "devops",
    "description": "DevOps setup with infrastructure, CI/CD, monitoring, and security tools"
  },
  "openclaw": { "version": "latest", "installMethod": "npm" },
  "identity": {
    "role": "DevOps / SRE Engineer",
    "soulTemplate": "devops"
  },
  "skills": {
    "fromAifleet": [
      "infra-patrol", "release-skills", "commit-helper",
      "github-pr-creation", "security-best-practices",
      "search-first", "grammar-check", "n8n-automation"
    ],
    "fromClawhub": [],
    "custom": []
  },
  "agents": [
    { "name": "main", "role": "Infrastructure and deployment assistant", "jobs": ["ci-cd", "monitoring", "incident-response"] },
    { "name": "ops", "role": "Operations specialist", "jobs": ["automation", "security-scanning"] }
  ],
  "config": {
    "autonomy": "L2-semi",
    "modelRouting": "balanced",
    "memoryChunks": 72
  },
  "cron": [
    { "schedule": "*/30 * * * *", "job": "infra-health-check", "description": "Check infrastructure health every 30 min" }
  ],
  "mcpServers": ["github"],
  "extensions": []
}
